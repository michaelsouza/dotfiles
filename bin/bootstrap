#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

check_dep() {
  local cmd="$1"
  local hint="$2"
  local ver_flag="${3:---version}"
  if command -v "$cmd" >/dev/null 2>&1; then
    echo "$cmd: $( "$cmd" "$ver_flag" 2>&1 | sed -n '1p' )"
  else
    echo "$cmd: missing"
    if [[ -n "$hint" ]]; then
      echo "  $hint"
    fi
  fi
}

link_path() {
  local source_path="$1"
  local target_path="$2"

  if [ ! -e "$source_path" ]; then
    echo "missing source: $source_path" >&2
    exit 1
  fi

  if [ -e "$target_path" ] && [ ! -L "$target_path" ]; then
    echo "refusing to overwrite non-symlink: $target_path" >&2
    exit 1
  fi

  ln -sfn "$source_path" "$target_path"
  echo "$target_path -> $source_path"
}

mkdir -p "$HOME/.config"

link_path "$repo_dir/nvim/.config/nvim" "$HOME/.config/nvim"
link_path "$repo_dir/tmux/.config/tmux" "$HOME/.config/tmux"
link_path "$HOME/.config/tmux/tmux.conf" "$HOME/.tmux.conf"

# -- Zsh linking
if [[ -d "$repo_dir/zsh" ]]; then
  link_path "$repo_dir/zsh/.zshrc" "$HOME/.zshrc"
  link_path "$repo_dir/zsh/.zshenv" "$HOME/.zshenv"
  if [[ -f "$repo_dir/zsh/.p10k.zsh" ]]; then
    link_path "$repo_dir/zsh/.p10k.zsh" "$HOME/.p10k.zsh"
  fi
fi

# -- Dependency checks
check_dep tmux "Install it with your system package manager, for example: sudo apt install tmux" "-V"
check_dep nvim "See nvim/README.md for local installation notes."
check_dep zsh "sudo apt install zsh"
check_dep git "sudo apt install git"
check_dep curl "sudo apt install curl"

# -- Oh-My-Zsh auto-install
if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
  OMZ_INSTALL="$(mktemp)"
  trap "rm -f '$OMZ_INSTALL'" EXIT
  curl -fsSL -o "$OMZ_INSTALL" https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh || { echo "Failed to download OMZ install script." >&2; exit 1; }
  echo "Installing Oh-My-Zsh..."
  zsh "$OMZ_INSTALL" --unattended || { echo "Oh-My-Zsh installation failed." >&2; exit 1; }
  echo "Oh-My-Zsh installed."
else
  echo "Oh-My-Zsh: already installed"
fi

# -- Powerlevel10k auto-install
if [[ ! -d "$HOME/.p10k" ]]; then
  echo "Cloning Powerlevel10k..."
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$HOME/.p10k" || { echo "Powerlevel10k clone failed." >&2; exit 1; }
  P10K_OMZ_LINK="$HOME/.oh-my-zsh/custom/themes/powerlevel10k"
  if [[ -L "$P10K_OMZ_LINK" ]]; then
    rm -f "$P10K_OMZ_LINK"
  elif [[ -d "$P10K_OMZ_LINK" ]]; then
    rm -rf "$P10K_OMZ_LINK"
  fi
  ln -sfn "$HOME/.p10k" "$HOME/.oh-my-zsh/custom/themes/powerlevel10k"
  echo "Powerlevel10k installed."
else
  echo "Powerlevel10k: already installed"
fi

# -- External OMZ plugins
OMZ_CUSTOM="$HOME/.oh-my-zsh/custom/plugins"
for plugin in zsh-autosuggestions zsh-syntax-highlighting; do
  PLUGIN_DIR="$OMZ_CUSTOM/$plugin"
  if [[ ! -d "$PLUGIN_DIR" ]]; then
    git clone --depth=1 "https://github.com/zsh-users/$plugin.git" "$PLUGIN_DIR" || { echo "Failed to clone $plugin." >&2; exit 1; }
    echo "$plugin cloned."
  else
    echo "$plugin: already installed"
  fi
done
